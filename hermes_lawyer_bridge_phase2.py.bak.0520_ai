# ==================== 5. AI证据整理 ====================

def handle_evidence(params):
    """POST /api/lawyer/ai/evidence — AI证据整理"""
    case_id = params.get('case_id')
    evidence_list = params.get('evidence_list', [])
    
    if not case_id:
        return {'code': 400, 'message': '参数错误', 'data': {'error': '缺少 case_id'}}
    if not evidence_list or not isinstance(evidence_list, list):
        return {'code': 400, 'message': '参数错误', 'data': {'error': '缺少 evidence_list 或格式不正确'}}
    
    def process(p, uid, pid):
        return {
            'evidence_catalog': '1. 合同类：\n   - 编号E001：合同原件（证明合同关系）\n   - 编号E002：合同补充协议\n2. 付款类：\n   - 编号E003：银行转账凭证\n   - 编号E004：收款收据\n3. 沟通类：\n   - 编号E005：催告函及回执\n   - 编号E006：微信聊天记录\n4. 其他类：\n   - 编号E007：律师函',
            'chain_analysis': '证据链完整度：85%\n\n核心证据链：合同(E001) → 付款凭证(E003) → 催告函(E005) → 违约事实证明\n\n待完善环节：\n- 建议补充被告的书面承诺或确认函\n- 建议对电子证据进行公证保全',
            'missing_suggestions': '1. 建议补充：被告身份信息证明文件\n2. 建议补充：合同履约过程中的全部往来邮件\n3. 建议获取：被告财产线索（用于财产保全）\n4. 建议公证：重要电子证据的公证文书'
        }
    
    return handle_ai_tool_request(params, 'evidence', process)


